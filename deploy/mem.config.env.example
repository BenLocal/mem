# mem service config — copy to /var/lib/mem/config.env and edit.
#
# Read by BOTH the systemd unit (EnvironmentFile=) and the supervisor
# wrapper (`source`), so values are intentionally UNQUOTED — systemd's
# EnvironmentFile can mishandle surrounding quotes, and none of these
# values contain spaces. Restart the service after editing.
#
# This mirrors the reference live deployment's variable set (2026-07-13).
# Everything below the "Baseline" section is an OPT-IN whose in-binary
# default is OFF/conservative — comment a line out (and restart) to fall
# back to the code default. The full knob catalog lives in CLAUDE.md
# («Key env vars») and README.

# ── Baseline ─────────────────────────────────────────────────────────

# Storage — a Lance dataset directory (single-writer: never point two
# `mem serve` processes at the same dir). Legacy dirs named `mem.duckdb`
# from pre-route-B installs keep working — the name is historical, the
# contents are Lance datasets either way.
MEM_DB_PATH=/var/lib/mem/mem.lance
MEM_TENANT=local

# HTTP bind
BIND_ADDR=127.0.0.1:3000

# Embedding provider:
#   fake          = offline, deterministic hash vectors (no model needed —
#                   the zero-dependency choice for smoke tests / CI)
#   embedanything = local CPU Qwen3-Embedding-0.6B (pre-download via
#                   scripts/download_model.py; HF_HOME points the cache)
#   openai        = needs OPENAI_API_KEY; sends content off this machine
EMBEDDING_PROVIDER=embedanything
HF_HOME=/var/lib/mem/hf-cache
# OPENAI_API_KEY=
# MEM_PRIVACY_WARN_SUPPRESS=1

# Cap embedanything (Candle + gemm + rayon, CPU) inference parallelism.
# Default rayon pool = nproc; on a many-core shared box each embed burst
# grabs ~18+ cores and spawns an nproc-wide thread pool. 8 keeps the
# 0.6B model fast (~1-2s, well under the 10s worker tick) without
# monopolizing the machine.
RAYON_NUM_THREADS=8

# Cap glibc malloc arenas (default = 8*nproc). Per-thread arenas retain
# freed memory, so under spawn_blocking/rayon thread churn RSS ramps to a
# high-water mark that looks like a leak. Same "cap a per-core-scaling
# resource" class as RAYON_NUM_THREADS.
MALLOC_ARENA_MAX=8

# ── Storage backend (default: lance, embedded) ──────────────────────
# All three backends are compiled in; pick with MEM_BACKEND and supply
# the matching URL (credentials in the URL). See docs/postgres-backend.md
# and docs/clickhouse-backend.md.
# MEM_BACKEND=postgres
# MEM_POSTGRES_URL=postgres://user:pass@127.0.0.1:5432/mem
# MEM_BACKEND=clickhouse
# MEM_CLICKHOUSE_URL=http://user:pass@127.0.0.1:8123/mem

# ── Governance opt-ins (code default OFF; operator policy) ───────────

# Idle-archive worker: archives Active capsules that are never-recalled
# AND aged ≥14d AND never-reinforced AND decay ≥0.15 AND structurally
# low-value, on a 24h cadence. The structural clause spares substantive
# lessons.
MEM_IDLE_ARCHIVE_ENABLED=1

# Ingest quality gate: rejects structurally low-value experience capsules
# at write time (too short / bare commit subject without evidence/refs).
MEM_INGEST_QUALITY_GATE_ENABLED=1

# ── Capsule self-evolution worker (OBSERVE posture) ──────────────────
# NOTE: there is NO propose-only mode — an enabled worker WILL execute an
# operation once its candidate holds for K CONSECUTIVE daily sweeps, so
# the observation window is K x interval (5 x 24h => first possible real
# execution ~5 days after the enabling restart). Preview pending evidence
# any time with:  POST /reviews/evolution {"dry_run":true}
# Kill switch: comment MEM_EVOLUTION_ENABLED out + restart.
MEM_EVOLUTION_ENABLED=1
MEM_EVOLUTION_K_CYCLES=5
# synthesis=review: generalize output lands as a raw-material placeholder
# in the pending-review queue, never generated prose (the worker is
# LLM-free). Interval / thresholds stay at code defaults
# (86400s / cluster 0.80 / merge 0.88).
MEM_EVOLUTION_SYNTHESIS=review

# ── G4 zero-LLM contradiction auto-invalidation ──────────────────────
# Comma-separated graph predicates treated as FUNCTIONAL (single-valued):
# a new (from, predicate, to) edge auto-closes existing active edges with
# the same (from, predicate). CAUTION: list ONLY genuinely single-valued
# predicates — a multi-valued one (uses, mentions_file, discusses) would
# wrongly close valid edges. Closures show in /metrics::kg_auto_invalidated.
MEM_KG_FUNCTIONAL_PREDICATES=located_in,current_status

# ── I2 offline reranker lane (docs/offline-reranker-lane.md) ─────────
# Cross-encoder gate on evolution merge candidates: each would-be loser
# scores bidirectionally against the survivor with Qwen3-Reranker-0.6B
# (loaded per batch, ~700ms/pair CPU, never resident); a bidirectional
# geometric mean under the floor (default 0.5) cancels the merge instead
# of archiving a same-topic-but-different-fact capsule. Rerank errors
# fail-closed-HOLD the candidate — the sweep never executes past a broken
# gate. Pre-warm the weights at MEM_RERANK_MODEL_DIR (no runtime HF
# download). Watch /metrics::rerank_pairs_total + rerank_merges_vetoed.
MEM_RERANK_OFFLINE_ENABLED=1
MEM_RERANK_MODEL_DIR=/var/lib/mem/hf-cache/manual/Qwen3-Reranker-0.6B

# ── Other worker / recall tuning (in-binary defaults shown) ──────────
# MEM_VACUUM_DISABLED=1
# MEM_VACUUM_INTERVAL_SECS=3600
# MEM_AUTO_PROMOTE_DISABLED=1
# MEM_DEDUP_ENABLED=1
# MEM_INGEST_NEARDUP_ENABLED=1     # O2/O7a write-time near-dup review flagging
# MEM_RECALL_PER_SOURCE_CAP=3      # O3 recall diversity cap (0 disables)
# MEM_RECALL_STYLE=index           # UserPromptSubmit banner style (snippet = legacy)
# MEM_MAX_INGEST_PER_SESSION=0     # per-session ingest throttle (0/unset = unbounded)
# EMBEDDING_BATCH_SIZE=8
# EMBEDDING_WORKER_POLL_INTERVAL_MS=10000
# MEM_REDACT_SECRETS_DISABLED=1    # O5 output/index-layer secret redaction is ON by default
