# mem service config — copy to /var/lib/mem/config.env and edit.
#
# Read by BOTH the systemd unit (EnvironmentFile=) and the supervisor
# wrapper (`source`), so values are intentionally UNQUOTED — systemd's
# EnvironmentFile can mishandle surrounding quotes, and none of these
# values contain spaces. Restart the service after editing.

# ── Storage (DuckDB is single-writer — never point two services here) ──
MEM_DB_PATH=/var/lib/mem/mem.duckdb
MEM_TENANT=local

# ── HTTP bind ──
BIND_ADDR=127.0.0.1:3000

# ── Embedding provider ──
# fake          = offline, deterministic hash vectors (no model needed)
# embedanything = local CPU Qwen3-Embedding-0.6B (run scripts/download_model.py
#                 first; HF_HOME points the cache into the data dir)
# openai        = needs OPENAI_API_KEY; sends content off this machine
EMBEDDING_PROVIDER=fake
HF_HOME=/var/lib/mem/hf-cache
# OPENAI_API_KEY=
# MEM_PRIVACY_WARN_SUPPRESS=1

# ── Optional worker tuning (in-binary defaults shown) ──
# MEM_VACUUM_DISABLED=1
# MEM_AUTO_PROMOTE_DISABLED=1
# MEM_DEDUP_ENABLED=1
# MEM_INGEST_NEARDUP_ENABLED=1     # O2 write-time near-dup review flagging
# MEM_RECALL_PER_SOURCE_CAP=3      # O3 recall diversity cap (0 disables)
